# ==========================================================
# Open Manuscript Initiative (OMI)
# Platform-independent .gitignore
# ==========================================================

# ----------------------------------------------------------
# Operating systems
# ----------------------------------------------------------

.DS_Store
Thumbs.db
Desktop.ini

# macOS
.AppleDouble
.LSOverride

# Windows
ehthumbs.db
*.lnk

# ----------------------------------------------------------
# Editors & IDEs
# ----------------------------------------------------------

.vscode/
.idea/
*.iml

# Visual Studio
.vs/

# Vim
*.swp
*.swo

# Emacs
*~

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------

*.log
logs/

# ----------------------------------------------------------
# Temporary files
# ----------------------------------------------------------

tmp/
temp/
.cache/

*.tmp
*.bak

# ----------------------------------------------------------
# Environment files
# ----------------------------------------------------------

.env
.env.*
!.env.example

# ----------------------------------------------------------
# Secrets
# ----------------------------------------------------------

*.pem
*.key
*.p12
*.pfx

# ----------------------------------------------------------
# Dependency directories
# (enabled when required)
# ----------------------------------------------------------

node_modules/
vendor/

# ----------------------------------------------------------
# Build output
# ----------------------------------------------------------

dist/
build/
out/

# ----------------------------------------------------------
# Coverage
# ----------------------------------------------------------

coverage/

# ----------------------------------------------------------
# Test output
# ----------------------------------------------------------

test-results/

# ----------------------------------------------------------
# Archives
# ----------------------------------------------------------

*.zip
*.tar
*.gz
*.7z

# ----------------------------------------------------------
# Local databases
# ----------------------------------------------------------

*.sqlite
*.sqlite3

# ----------------------------------------------------------
# Runtime files
# ----------------------------------------------------------

*.pid

# ----------------------------------------------------------
# Generated documentation
# ----------------------------------------------------------

site/

# ----------------------------------------------------------
# Local configuration
# ----------------------------------------------------------

.local/

# ----------------------------------------------------------
# OS-generated trash
# ----------------------------------------------------------

.Trashes/
.fseventsd/
